# Bright Data API Configuration
# Get your API token from: https://brightdata.com/cp/api_token
BRIGHT_DATA_API_TOKEN=your_bright_data_api_token_here

# Optional: Bright Data zone (defaults to 'mcp_unlocker' if not set)
# BRIGHT_DATA_ZONE=mcp_unlocker

# Optional: Anthropic API key
# Falls back to Claude Code CLI credentials (~/.claude/get-api-key.sh) if unset
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Protect the web UI API with a Bearer token
# When set, all API requests must include "Authorization: Bearer <key>"
# When unset, no auth (local development mode)
# CLAUDE_RESEARCHER_API_KEY=your_secret_api_key

# Optional: Allowed CORS origins for the API server (comma-separated)
# Defaults to http://localhost:3000,http://127.0.0.1:3000
# Set to * to allow all origins (not recommended for production)
# CLAUDE_RESEARCHER_CORS_ORIGINS=http://localhost:3000

